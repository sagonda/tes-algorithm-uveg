# ============================================================================
# TES ALGORITHM UVEG - ENVIRONMENT VARIABLES TEMPLATE
# ============================================================================
# Copy this file to .env and fill in your values
# WARNING: NEVER commit .env to version control (see .gitignore)
# ============================================================================

# ============================================================================
# DATA PATHS - REQUIRED
# ============================================================================

# Root directory where raw MODIS HDF5 files are stored
# Directory structure should be: $MODIS_DATA_PATH/YEAR/MONTH/DAYOFYEAR/
MODIS_DATA_PATH=/path/to/modis/raw/data

# Directory where processed netCDF4 output products will be written
# Will be created if doesn't exist
OUTPUT_PATH=/path/to/tes/processing/output

# Directory for temporary processing files (will be cleaned after each run)
TEMP_PATH=/path/to/tes/temp

# ============================================================================
# RTTOV RADIATIVE TRANSFER MODEL - REQUIRED
# ============================================================================

# Root directory of RTTOV installation
# Should contain subdirectories: emis_data/, cld_data/, etc.
RTTOV_ROOT_PATH=/path/to/rttov/v13

# Path to RTTOV GPM (Gas Profile Modelling) atmospheric data
RTTOV_GPM_PATH=/path/to/rttov/gpm/data

# Path to RTTOV emissivity database directory
RTTOV_EMIS_PATH=/path/to/rttov/emis_data

# RTTOV coefficient files directory (for MODIS)
RTTOV_COEFF_PATH=/path/to/rttov/rtcoef_rttov13/modis_terra

# ============================================================================
# PROCESSING PARAMETERS
# ============================================================================

# Year to process (e.g., 2023)
PROCESS_YEAR=2023

# Month to process (1-12)
PROCESS_MONTH=6

# Day of year to process (1-366), or leave empty to process entire month
# Example: PROCESS_DOY=177 (June 26 in non-leap year)
PROCESS_DOY=

# Number of parallel processes for multi-threaded processing (default: 4)
# Adjust based on your system's CPU cores
NUM_PROCESSES=4

# ============================================================================
# LOGGING AND DEBUG
# ============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Directory for log files
LOG_DIR=./logs

# Enable detailed error traceback (true/false)
VERBOSE_ERRORS=false

# Save intermediate processing results for debugging (true/false, impacts disk space)
SAVE_DEBUG_ARTIFACTS=false

# ============================================================================
# QUALITY ASSURANCE / QUALITY CONTROL
# ============================================================================

# Minimum cloud-free percentage to process a granule (0-100)
QA_MIN_CLEAR_PIXELS=10

# Maximum acceptable LST error threshold (Kelvin)
QA_MAX_LST_ERROR=2.0

# Validate outputs against SURFRAD ground truth data (true/false)
QA_COMPARE_SURFRAD=false

# Path to SURFRAD validation station data (if QA_COMPARE_SURFRAD=true)
QA_SURFRAD_DATA_PATH=/path/to/surfrad/data

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================

# Memory limit for single granule processing (MB)
MEMORY_LIMIT_MB=2048

# Chunk size for HDF5 file streaming (number of rows)
HDF5_CHUNK_SIZE=100

# Enable numpy BLAS multithreading (true/false)
ENABLE_BLAS_MT=true

# Number of BLAS threads (usually = NUM_PROCESSES)
BLAS_NUM_THREADS=4

# ============================================================================
# OPTIONAL: ADVANCED FEATURES
# ============================================================================

# Database connection for storing processing metadata (if tracking in DB)
# DATABASE_URL=postgresql://user:password@localhost:5432/tes_uveg

# Enable machine learning cloud detection refinement (experimental)
# ML_CLOUD_DETECTION=false

# Slack webhook for notifications on processing completion
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email notifications on error (comma-separated)
# ERROR_NOTIFICATION_EMAIL=admin@example.com,operator@example.com

# ============================================================================
# SECURITY - SECRET CREDENTIALS (HANDLE WITH CARE)
# ============================================================================

# API keys for optional cloud storage uploads (AWS S3, etc.)
# AWS_ACCESS_KEY_ID=your_aws_key_here
# AWS_SECRET_ACCESS_KEY=your_aws_secret_here
# AWS_S3_BUCKET=tes-uveg-products

# ============================================================================
# END OF CONFIGURATION
# ============================================================================
# Note: Lines starting with # are comments and are ignored
# Boolean values: true, false, yes, no (case-insensitive)
# Paths can be absolute or relative to project root
# Empty values represent optional/disabled features
# ============================================================================
