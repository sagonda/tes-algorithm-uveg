# .gitattributes - Ensure Consistent Line Endings Across Platforms

# ============================================================================
# Global Settings
# ============================================================================
# Normalize line endings to LF in repository, but use native on checkout
* text=auto

# ============================================================================
# Python Files
# ============================================================================
*.py text eol=lf
*.pyw text eol=lf
*.pyx text eol=lf
*.pxd text eol=lf
*.pyi text eol=lf

# ============================================================================
# Shell Scripts
# ============================================================================
*.sh text eol=lf
*.bash text eol=lf

# ============================================================================
# Documentation
# ============================================================================
*.md text eol=lf
*.markdown text eol=lf
*.rst text eol=lf
*.txt text eol=lf

# ============================================================================
# Configuration Files
# ============================================================================
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.env text eol=lf
.env.example text eol=lf
.editorconfig text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.conf text eol=lf

# ============================================================================
# Jupyter Notebooks (JSON-based, should not have newlines altered)
# ============================================================================
*.ipynb text eol=lf diff=jupyter

# ============================================================================
# Windows-Specific Files
# ============================================================================
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# ============================================================================
# Binary Files - Do Not Touch
# ============================================================================
*.hdf5 binary
*.h5 binary
*.nc binary
*.nc4 binary
*.netcdf binary
*.fits binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.zip binary
*.tar binary
*.tar.gz binary

# ============================================================================
# Large Files (Optional: Requires Git LFS)
# ============================================================================
# Uncomment if using Git LFS for large data files
# *.hdf5 filter=lfs diff=lfs merge=lfs -text
# *.nc filter=lfs diff=lfs merge=lfs -text
# *.fits filter=lfs diff=lfs merge=lfs -text

# ============================================================================
# Git Merge Attributes
# ============================================================================
# Prevent conflicts on commonly modified files
CHANGELOG.md merge=union
VERSION merge=union
