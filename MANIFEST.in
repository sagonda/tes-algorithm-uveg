# MANIFEST.in - Distribution file inclusion rules

# Include all markdown documentation
include README.md
include CHANGELOG.md
include CONTRIBUTING.md
include CODE_OF_CONDUCT.md
include ARCHITECTURE.md
include SECURITY.md
include COPYRIGHT
include LICENSE
include .gitignore
include .gitattributes
include .env.example
include requirements.txt

# Include Python packages
recursive-include services *.py
recursive-include utilities *.py
recursive-include tests *.py

# Exclude cache and build artifacts
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *$py.class
global-exclude *.so
global-exclude .git
global-exclude .vscode
global-exclude .idea
global-exclude .pytest_cache
global-exclude .mypy_cache
global-exclude build
global-exclude dist
global-exclude *.egg-info
